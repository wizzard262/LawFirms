@BaseAddress = https://localhost:7113

### ── LawFirms ──────────────────────────────────────────────────────────────

# GET all law firms (with optional pagination)
GET {{BaseAddress}}/lawfirms?pageNumber=1&pageSize=20&sortOrder=asc
Accept: application/json

###

# GET all law firms (with optional pagination)
GET {{BaseAddress}}/lawfirms?pageNumber=1&pageSize=20&sortOrder=desc
Accept: application/json

###

# GET all law firms (with optional pagination) - sort order defaults to ASCENDING
GET {{BaseAddress}}/lawfirms?pageNumber=1&pageSize=20
Accept: application/json

###

# GET a law firm by ID
GET {{BaseAddress}}/lawfirms/{{lawFirmId}}
Accept: application/json

###

# POST create a new law firm
POST {{BaseAddress}}/lawfirms
Content-Type: application/json
X-User-Id: aaaaaaaa-0000-0000-0000-000000000001

{
  "id": "ffffffff-0000-0000-0000-000000000001",
  "name": "Acme Law",
  "address": "123 Main St, Dublin",
  "phoneNumber": "+353 1 234 5678",
  "email": "contact@acmelaw.ie"
}

###

# PUT update an existing law firm
PUT {{BaseAddress}}/lawfirms/{{lawFirmId}}
Content-Type: application/json
X-User-Id: aaaaaaaa-0000-0000-0000-000000000001

{
  "id": "{{lawFirmId}}",
  "name": "Acme Law Updated",
  "address": "456 High St, Dublin",
  "phoneNumber": "+353 1 234 5678",
  "email": "info@acmelaw.ie"
}

### ── Documents ─────────────────────────────────────────────────────────────

# GET all documents (with optional pagination)
GET {{BaseAddress}}/documents?pageNumber=1&pageSize=20
Accept: application/json

###

# GET a document by ID
GET {{BaseAddress}}/documents/{{documentId}}
Accept: application/json

###

# POST create a new document
POST {{BaseAddress}}/documents
Content-Type: application/json
Headers:
  x-user-id: aaaaaaaa-0000-0000-0000-000000000001

{
  "id": "dddddddd-0000-0000-0000-000000000001",
  "title": "Contract Agreement",
  "type": "Contract",
  "lawFirmId": "ffffffff-0000-0000-0000-000000000001",
  "uploadedBy": "aaaaaaaa-0000-0000-0000-000000000001",
  "uploadedAt": "2025-01-01T00:00:00Z",
}

###

# PUT update an existing document
PUT {{BaseAddress}}/documents/{{documentId}}
Content-Type: application/json

{
  "id": "{{documentId}}",
  "title": "Contract Agreement (Revised)",
  "type": "Contract",
  "lawFirmId": "{{lawFirmId}}",
  "uploadedBy": "aaaaaaaa-0000-0000-0000-000000000001",
  "uploadedAt": "2025-01-01T00:00:00Z"
}
